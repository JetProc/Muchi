NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# 서버 전용: 공개 기록 사진 검증/조회에 사용합니다. 브라우저에 노출하지 마세요.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# Apple Developer > Keys에서 만든 MusicKit 키 (서버 전용 — NEXT_PUBLIC_ 접두사 사용 금지)
APPLE_MUSIC_TEAM_ID=YOUR_APPLE_DEVELOPER_TEAM_ID
APPLE_MUSIC_KEY_ID=YOUR_MUSICKIT_KEY_ID
APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
# YouTube Data API v3 키 (YouTube Music 플레이리스트 링크 가져오기용, 서버 전용)
YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_KEY
